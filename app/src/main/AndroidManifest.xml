<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        FlightBox is intentionally OFFLINE. We do NOT declare INTERNET.
        The app reads videos from a user-picked folder via SAF
        (Storage Access Framework), which does not require any runtime
        media permission because the user grants the URI directly.
    -->

    <application
        android:name=".FlightBoxApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlightBox">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            PlayerActivity is locked to LANDSCAPE — the player is
            designed to be a landscape-only experience: top 2/3 video,
            bottom 1/3 thumbnail strip. We do NOT auto-rotate, and
            the user does not have a way to flip it (the only way out
            of the activity is the back arrow / system back). MainActivity
            remains portrait because folder selection is a portrait task.
        -->
        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.FlightBox.Player" />

    </application>

</manifest>