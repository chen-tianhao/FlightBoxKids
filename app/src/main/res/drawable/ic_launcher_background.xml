<?xml version="1.0" encoding="utf-8"?>
<!--
  FlightBox app icon background.
  Diagonal sky gradient: light sky-blue at top-left to deep blue at
  bottom-right, evoking "sky / flight" for the FlightBox brand.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:startColor="#60A5FA"
                android:endColor="#1E40AF" />
        </aapt:attr>
    </path>
</vector>
