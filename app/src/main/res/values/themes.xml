<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FlightBox" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">@color/brand_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/brand_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!--
        Player theme: same as the main theme but with a black backdrop so
        the activity window behind any letterboxed video does not flash
        the brand blue. We also force light status-bar icons off.
    -->
    <style name="Theme.FlightBox.Player" parent="Theme.FlightBox">
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>